@startuml

actor Authenticated_User as user 

participant Browser as a 
participant EventController as b 
participant EventService as c 
participant EventRepository as d 
database Database as e 

user -> a: 1. Click "Sự kiện" button
a -> b++: 2. Send a request
b -> c++: 3. Call getAllEventByDivisionID()
c -> d++: 4. Call getEventByDivisionID()
d -> e++: 5. Query

e --> d--: 6. Return result
d --> c--: 7. Return result
c --> b--: 8. Return response
b --> a--: 9. Return response
@enduml